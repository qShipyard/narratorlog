# PostgreSQL
POSTGRES_PASSWORD=change-this-strong-password

# Database
DATABASE_URL=postgresql://narratorlog:change-this-strong-password@postgres:5432/narratorlog?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379

# App
APP_SECRET=change-this-to-a-random-32-character-string
APP_URL=https://your-domain.com
ENCRYPTION_KEY=change-this-to-a-random-32-character-string

# Domain (for nginx SSL config)
DOMAIN=your-domain.com